# Public legal identity. Use the exact legal name shown on the EIN letter if it differs from the DBA.
NEXT_PUBLIC_LEGAL_BUSINESS_NAME=Cole's Mobile Detailing

# Digital Forge lead connection (required)
DF_PLATFORM_URL=https://digitalforgeplatform.netlify.app
DF_PLATFORM_WORKSPACE_ID=cmd
DF_PLATFORM_INGEST_KEY=replace-with-the-same-cmd-ingest-key
DF_OWNER_DASHBOARD_URL=https://digitalforgeplatform.netlify.app/dashboard/leads

# AI assistant (server-side only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Owner-only operational SMS alerts through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Use a Messaging Service SID instead of TWILIO_FROM_NUMBER when configured.
TWILIO_MESSAGING_SERVICE_SID=
OWNER_NOTIFICATION_PHONE=
# Must be explicitly true only after the owner/authorized recipient has opted in.
OWNER_SMS_OPTED_IN=false
